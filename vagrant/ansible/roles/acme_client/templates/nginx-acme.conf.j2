# Managed by Ansible (acme_client role). Do not edit by hand.

# HTTP-01 webroot — step-ca will GET /.well-known/acme-challenge/<token>
# during validation, so this site must be reachable on port 80 from stepca1
# at every name in the AD DNS A records list (acme1, step.acme1, sh.acme1,
# cb.acme1, alpn.acme1).
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name acme1.{{ lab_domain }} step.acme1.{{ lab_domain }} sh.acme1.{{ lab_domain }} cb.acme1.{{ lab_domain }} alpn.acme1.{{ lab_domain }};

    root /var/www/html;
    index index.html;

    location /.well-known/acme-challenge/ {
        # Webroot for both step CLI (--webroot) and acme.sh (-w)
        root /var/www/html;
        # ACME challenge files are served as plain text, no extensions
        default_type "text/plain";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}


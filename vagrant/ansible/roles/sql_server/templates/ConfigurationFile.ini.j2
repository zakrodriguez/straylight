; SQL Server {{ sql_server_version }} {{ sql_server_edition }} unattended install
; Generated by straylight sql_server role for sqlhost1
;
; SQL Server install reference:
;   https://learn.microsoft.com/sql/database-engine/install-windows/install-sql-server-from-the-command-prompt
;
; This config installs:
;   - Default instance (MSSQLSERVER)
;   - Database Engine only (no SSAS/SSRS/SSIS — keep the surface small)
;   - Mixed-mode authentication
;   - SQL service running as {{ sql_engine_account }} (domain service account)
;   - TCP/IP protocol enabled, listening on port {{ sql_tcp_port }}
;   - Domain Admins + lab Administrator as sysadmins

[OPTIONS]
ACTION="Install"
ENU="True"
QUIET="True"
QUIETSIMPLE="False"
UpdateEnabled="False"
USEMICROSOFTUPDATE="False"
SUPPRESSPAIDEDITIONNOTICE="True"
SUPPRESSPRIVACYSTATEMENTNOTICE="True"
IACCEPTSQLSERVERLICENSETERMS="True"

; Features
FEATURES={{ sql_features }}

; Instance
INSTANCENAME="{{ sql_instance_name }}"
INSTANCEID="{{ sql_instance_name }}"
INSTANCEDIR="{{ sql_install_dir }}"

; Service accounts
SQLSVCACCOUNT="{{ sql_engine_account }}"
SQLSVCPASSWORD="{{ sql_engine_password }}"
SQLSVCSTARTUPTYPE="Automatic"
AGTSVCACCOUNT="NT AUTHORITY\NETWORK SERVICE"
AGTSVCSTARTUPTYPE="Disabled"

; Authentication + sysadmins
SECURITYMODE="{{ sql_security_mode }}"
SAPWD="{{ sql_sa_password }}"
SQLSYSADMINACCOUNTS={% for a in sql_sysadmin_accounts %}"{{ a }}"{% if not loop.last %} {% endif %}{% endfor %}


; Data + log paths
SQLUSERDBDIR="{{ sql_data_dir }}"
SQLUSERDBLOGDIR="{{ sql_log_dir }}"
SQLTEMPDBDIR="{{ sql_data_dir }}\TempDB"
SQLTEMPDBLOGDIR="{{ sql_log_dir }}\TempDB"

; Network protocols
TCPENABLED="{% if sql_tcp_enabled %}1{% else %}0{% endif %}"
NPENABLED="0"

; Browser
BROWSERSVCSTARTUPTYPE="{% if sql_browser_enabled %}Automatic{% else %}Disabled{% endif %}"

; Telemetry off (lab environment)
SQLTELSVCSTARTUPTYPE="Disabled"

[Version]
Signature="$Windows NT$"

[PolicyStatementExtension]
Policies=InternalPolicy

[InternalPolicy]
OID=1.3.6.1.4.1.99999.1.1
Notice="This PQC CA is for internal lab use only"

[Certsrv_Server]
RenewalKeyLength={{ ca_key_length }}
RenewalValidityPeriod={{ ca_validity_period }}
RenewalValidityPeriodUnits={{ ca_validity_period_units }}
; Issuing CA CRL validity: 26 weeks (~6 months) to match root cadence and the
; lab's cold-start window; delta CRL (daily) remains the near-real-time signal.
CRLPeriod=Weeks
CRLPeriodUnits=26
CRLDeltaPeriod=Days
CRLDeltaPeriodUnits=1
LoadDefaultTemplates=0
# AlternateSignatureAlgorithm is an RSA-PSS-only knob; a no-op for ML-DSA. Set
# explicitly to 0 so it never triggers an RSA-PSS path on a non-RSA key.
AlternateSignatureAlgorithm=0

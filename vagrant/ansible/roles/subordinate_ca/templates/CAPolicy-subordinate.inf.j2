[Version]
Signature="$Windows NT$"

[PolicyStatementExtension]
Policies=InternalPolicy

[InternalPolicy]
OID=1.3.6.1.4.1.99999.1.1
Notice="This CA is for internal lab use only"

[Certsrv_Server]
RenewalKeyLength={{ ca_key_length }}
RenewalValidityPeriod={{ ca_validity_period }}
RenewalValidityPeriodUnits={{ ca_validity_period_units }}
; Issuing CA CRL validity: 26 weeks (~6 months) to match root CA cadence.
; Previously 2 weeks, which caused cold-start FAIL on labs left idle 2+
; weeks (validate.sh chain check, manage1 revocation checks). The longer
; window covers expected cold-start gaps; delta CRL (daily) remains the
; near-real-time revocation signal.
CRLPeriod=Weeks
CRLPeriodUnits=26
CRLDeltaPeriod=Days
CRLDeltaPeriodUnits=1
LoadDefaultTemplates=0
AlternateSignatureAlgorithm=0

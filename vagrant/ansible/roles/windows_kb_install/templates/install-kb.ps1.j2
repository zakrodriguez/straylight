# Render-time params from the Ansible role (Jinja2 substitutes once at copy time):
$KbNumber  = "{{ kb_number }}"
$WorkDir   = "{{ kb_install_workdir }}"
$Timeout   = {{ kb_install_wusa_timeout }}

# Runtime state on the target VM:
$ErrorActionPreference = 'Stop'
$msuPath    = Join-Path $WorkDir "$KbNumber.msu"
$logPath    = Join-Path $WorkDir "$KbNumber-install.log"
$statusFile = Join-Path $WorkDir "$KbNumber.status"
$rcFile     = Join-Path $WorkDir "$KbNumber.rc"
$innerPs1   = Join-Path $WorkDir "wusa-inner-$KbNumber.ps1"

if (Test-Path $statusFile) { Remove-Item $statusFile -Force }
if (Test-Path $rcFile)     { Remove-Item $rcFile -Force }

# wusa.exe command line.
#   /quiet     — unattended
#   /norestart — leave reboot to Ansible (we decide based on rc=3010)
#   /log:      — verbose CBS/WindowsUpdate trace for forensic debugging
$wusaArgs = @('"{0}"' -f $msuPath, '/quiet', '/norestart', ('/log:"{0}"' -f $logPath))

# Inner script run by the SYSTEM-context scheduled task.  Single-quoted
# here-string so PowerShell does NO interpolation at write time — the inner
# script uses its own $variables at run time.
$innerScript = @'
$ErrorActionPreference = 'Stop'
$msu        = $args[0]
$log        = $args[1]
$statusFile = $args[2]
$wusa = Start-Process -FilePath 'wusa.exe' `
    -ArgumentList @("`"$msu`"", '/quiet', '/norestart', "/log:`"$log`"") `
    -Wait -PassThru -NoNewWindow
Set-Content -Path $statusFile -Value ("rc={0}" -f $wusa.ExitCode)
'@
Set-Content -Path $innerPs1 -Value $innerScript -Encoding ASCII

# wusa.exe under WinRM Basic auth hits a restricted-token error
# (network logon + DPAPI).  SYSTEM-context scheduled task is the canonical
# straylight workaround (mirrors sql_server role's SqlServerSetup pattern).
$action = New-ScheduledTaskAction `
    -Execute 'powershell.exe' `
    -Argument ('-NoProfile -ExecutionPolicy Bypass -File "{0}" "{1}" "{2}" "{3}"' `
        -f $innerPs1, $msuPath, $logPath, $statusFile)
$principal = New-ScheduledTaskPrincipal `
    -UserId 'NT AUTHORITY\SYSTEM' `
    -LogonType ServiceAccount -RunLevel Highest

Register-ScheduledTask -TaskName 'WindowsKBInstall' `
    -Action $action -Principal $principal -Force | Out-Null
Start-ScheduledTask -TaskName 'WindowsKBInstall'

# Poll for completion.  Task transitions Ready -> Running -> Ready;
# waiting until Ready after Start is the canonical finish indicator.
$waited = 0
while ($waited -lt $Timeout) {
    Start-Sleep -Seconds 15
    $waited += 15
    $task = Get-ScheduledTask -TaskName 'WindowsKBInstall' -ErrorAction SilentlyContinue
    if ($task -and $task.State -eq 'Ready') { break }
}
Unregister-ScheduledTask -TaskName 'WindowsKBInstall' -Confirm:$false -ErrorAction SilentlyContinue

if (-not (Test-Path $statusFile)) {
    throw ("wusa.exe scheduled task did not write status file after {0} seconds (see {1})" -f $waited, $logPath)
}

$rc = (Get-Content $statusFile).Split('=')[1].Trim()
Write-Output ("wusa.exe exit code: {0}" -f $rc)
Set-Content -Path $rcFile -Value $rc

# 0       = success
# 3010    = success, reboot required
# 2359302 = WU_S_ALREADY_INSTALLED (0x240006)
if ($rc -notin @('0', '3010', '2359302')) {
    throw ("wusa.exe failed installing {0} with rc={1} (see {2} for details)" -f $KbNumber, $rc, $logPath)
}

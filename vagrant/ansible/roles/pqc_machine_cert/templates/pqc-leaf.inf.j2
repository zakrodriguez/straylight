[Version]
Signature="$Windows NT$"

[NewRequest]
; ML-DSA leaf request, matching Microsoft's documented ML-DSA TLS template
; procedure (Configure certificate templates for ML-DSA / "Configure a TLS
; certificate template with ML-DSA"). KeyAlgorithm + ProviderName are derived
; from the CA's crypto provider ("ML-DSA:65#Microsoft Software Key Storage
; Provider"):
;   {{ pqc_inf_crypto_provider.split('#')[0] }}  /  {{ pqc_inf_crypto_provider.split('#')[1] }}
; KeySpec MUST be AT_SIGNATURE and HashAlgorithm NoHash (ML-DSA is pure,
; signature-only). ProviderType 0 selects the CNG KSP named by ProviderName.
; The enterprise template is AD-bound (msPKI-Certificate-Name-Flag = 134217728,
; SUBJECT_ALT_REQUIRE_DNS, with ENROLLEE_SUPPLIES_SUBJECT unset = ESC1-safe), so
; the CA ignores this placeholder Subject and builds the DNS SAN from the
; requesting machine's AD object. Run as SYSTEM so the machine identity reaches
; the CA. MachineKeySet=TRUE lands the key in the LocalMachine store.
Subject = "CN={{ inventory_hostname }}.{{ lab_domain }}"
KeyAlgorithm = "{{ pqc_inf_crypto_provider.split('#')[0] }}"
KeySpec = AT_SIGNATURE
HashAlgorithm = NoHash
ProviderName = "{{ pqc_inf_crypto_provider.split('#')[1] }}"
ProviderType = 0
MachineKeySet = TRUE
RequestType = PKCS10
Exportable = FALSE
SMIME = False

[EnhancedKeyUsageExtension]
OID=1.3.6.1.5.5.7.3.1
Critical=FALSE

[Extensions]
2.5.29.19 = "{text}CA=FALSE"

[RequestAttributes]
CertificateTemplate = {{ pqc_template_name }}

services:
  gitea:
    image: gitea/gitea:{{ gitea_tag }}
    container_name: gitea
    ports:
      - "3000:3000"
      - "222:22"
    environment:
      GITEA__database__DB_TYPE: sqlite3
      USER_UID: "1000"
      USER_GID: "1000"
    volumes:
      - /opt/gitea/data:/data
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:3000/ || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
    restart: unless-stopped

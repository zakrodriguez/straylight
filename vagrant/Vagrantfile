                       "--target", :id,
                       "--name", "YubiHSM2",
                       "--vendorid", "1050",
                       "--productid", "0030"]
      end
    end

    # Disable default synced folder (re-enable with SSH-compatible type)
    ejbca.vm.synced_folder ".", "/vagrant", disabled: true
    ejbca.vm.synced_folder SOFTWARE_PATH, "/software", type: "virtualbox" if SOFTWARE_AVAILABLE


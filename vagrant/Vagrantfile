# -*- mode: ruby -*-
# vi: set ft=ruby :
require 'fileutils'
#===============================================================================
# Straylight PKI Lab
#===============================================================================
# Active VM set is selected by LAB_PROFILE (resolved via lib/lab_profile.rb).
# See `bash up.sh --list-profiles` for the full list — common choices:
#
#   core             DC1, CA1, WEB1, MANAGE1 (default, ~15 min)
#   ad-cs-two-tier   DC1, ROOTCA, ISSUECA, WEB1, MANAGE1
#   pqc-full         two-tier + PQC AD CS (ROOTCA-PQC, ISSUECA-PQC) + EJBCA +
#                    step-ca + Hydra + OBSERVE1 + SCANNER1 + ACME1
#                    (13 VMs, post-quantum demo)
#   full             18 VMs — every classical-stack VM (backstop; excludes the
#                    PQC AD CS pair, which only the pqc-* profiles build)
#
# Provisioning: Ansible (per-VM invocation)
# Orchestration: up.sh (profile-aware parallel launch)
#===============================================================================

require_relative "lib/lab_env"   # load vagrant/.env BEFORE config.rb reads ENV

# ── Active lab profile resolution ─────────────────────────────────
# Resolve BEFORE config.rb so the dynamically-allocated /24 feeds LAB_NETWORK /
# IP_ADDRESSES. An explicit LAB_NETWORK (shell or .env) still wins; otherwise
# LabNetwork grabs the lowest free host-only /24 from the base up, skipping
# subnets already used by other running labs (lib/lab_network.rb).
require_relative "lib/lab_profile"
require_relative "lib/lab_network"
PROFILE    = LabProfile.resolve
# Treat empty/blank as unset ("" is truthy in Ruby, so a bare `LAB_NETWORK=
# vagrant up` would otherwise pin Topology.network to "" and break IPs/PORT_OFFSET).
if ENV["LAB_NETWORK"].to_s.strip.empty?
  own_vms = PROFILE[:components].map { |c| "#{PROFILE[:vbox_prefix]}-#{c}" }
  ENV["LAB_NETWORK"] = LabNetwork.for_lab(PROFILE[:vbox_prefix], own_vms: own_vms)
end
require_relative "config"
COMPONENTS = PROFILE[:components]
RESOURCES  = PROFILE[:resources]

# Set dotfile path before Vagrant initializes, unless user explicitly overrode.
ENV["VAGRANT_DOTFILE_PATH"] ||= PROFILE[:dotfile_dir]
$stderr.puts "[lab_profile] active: #{PROFILE[:name]} (#{COMPONENTS.size} VMs, source=#{PROFILE[:source]})"

# Per-VM resource override helpers — applied alongside VM_DEFAULTS.
def vm_memory(vm_name, default)
  (RESOURCES[vm_name] || {})["memory"] || default
end
def vm_cpus(vm_name, default)
  (RESOURCES[vm_name] || {})["cpus"] || default
end

# Box freshness contract. Assigns vm.box and, when a straylight/*
# box is in use AND STRAYLIGHT_BOX_VERSION is pinned (config.rb), pins
# vm.box_version too so a stale local bake can't silently satisfy `vagrant up`.
# Upstream gusztavvargadr boxes are left to Vagrant's default version
# resolution (they carry their own published versions).
def set_box(vm, box)
  vm.vm.box = box
  if box.to_s.start_with?("straylight/") && STRAYLIGHT_BOX_VERSION
    vm.vm.box_version = STRAYLIGHT_BOX_VERSION
  end
end


# Path to ansible directory
ANSIBLE_DIR = File.expand_path("ansible", __dir__)

# Domain DN derived from domain name (e.g., "yourlab.local" -> "DC=yourlab,DC=local")
DOMAIN_DN = LAB_DOMAIN.split('.').map { |dc| "DC=#{dc}" }.join(',')

# VirtualBox VM name prefix (preserves existing naming convention)
VB_PREFIX = ENV["VB_PREFIX"] || PROFILE[:vbox_prefix]

# Port offset for static forwarded ports (avoids collisions when running
# multiple topologies on different subnets simultaneously).
# Default subnet .56 = offset 0; .57 = offset +1000, etc.
PORT_OFFSET = (LAB_NETWORK.split('.').last.to_i - 56) * 1000


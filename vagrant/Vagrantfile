      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/apps1.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge(APPS_VARS).merge({ ip_address: IP_ADDRESSES[:apps1] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end
  end
  end  # COMPONENTS.include?("apps1")
end

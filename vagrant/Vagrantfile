# Parallel PQC AD CS hierarchy.  Requires KB5087539
# on the target VM (the windows_kb_install role + fetch-windows-kb.sh
# helper land that).  ML-DSA is GA on Server 2025 ≥ 26100.32860.
#
# Provider naming convention follows Microsoft's published format
# (learn.microsoft.com/.../configure-ml-dsa-certification-authority):
#   ML-DSA:65#Microsoft Software Key Storage Provider
# Key length is the PUBLIC key size in bits — ML-DSA-65 = 1952 B × 8.
# Hash algorithm MUST be NoHash; ML-DSA does internal hashing and
# rejects external SHA configurations at install time.
#
# These vars drive the unified standalone_ca / subordinate_ca roles in
# ML-DSA mode (CryptoProviderName = ca_crypto_provider); the same roles
# build the classical RSA hierarchy when the vars are absent.
ROOT_CA_PQC_VARS = {
  ca_common_name: "#{LAB_NETBIOS}-PQC-Root-CA",
  ca_type: "StandaloneRootCA",
  ca_key_length: 20736,                            # ML-DSA-87 public key, bits
  ca_crypto_provider: "ML-DSA:87#Microsoft Software Key Storage Provider",
  ca_hash_algorithm: "NoHash",                     # mandatory for ML-DSA
  ca_validity_period: "Years",
  ca_validity_period_units: PKI_CONFIG[:validity_years][:root],
  crl_url: PKI_CONFIG[:crl_url_pqc],               # separate PQC CDP/AIA namespace
  aia_url: PKI_CONFIG[:aia_url_pqc],
  kb_prereq: "KB5087539",                          # consumed by windows_kb_install role
}

ISSUING_CA_PQC_VARS = {
  ca_common_name: "#{LAB_NETBIOS}-PQC-Issuing-CA",
  ca_type: "EnterpriseSubordinateCA",
  ca_key_length: 15616,                            # ML-DSA-65 public key, bits
  ca_crypto_provider: "ML-DSA:65#Microsoft Software Key Storage Provider",
  ca_hash_algorithm: "NoHash",                     # mandatory for ML-DSA
  ca_validity_period: "Years",
  ca_validity_period_units: PKI_CONFIG[:validity_years][:issuing],
  crl_url: PKI_CONFIG[:crl_url_pqc],               # separate PQC CDP/AIA namespace
  aia_url: PKI_CONFIG[:aia_url_pqc],
  parent_ca_ip: IP_ADDRESSES[:"rootca-pqc"],
  parent_ca_name: "#{LAB_NETBIOS}-PQC-Root-CA",
  kb_prereq: "KB5087539",
}

#===============================================================================
# Static Ansible inventory — generated by lib/render_inventory.rb on demand.
#
# Generation is an EXPLICIT step: RenderInventory.run runs only when
# LAB_RENDER_INVENTORY=1 (set by up.sh / render-inventory.sh) or on first run.
# The path constants below stay here because the per-VM provisioner blocks
# reference INVENTORY_PATH; the generation logic itself moved to the module.
#
# Per-profile inventory directories (approach B: profile subdirectory) prevent
# the write race when two profiles are running concurrently on the same checkout
# (`LAB_PROFILE=core vagrant up` + `LAB_PROFILE=pqc-linux vagrant up` in
# different terminals). Each profile writes only under
# `inventory/<profile-name>/`, so the two never clobber each other.
#
# Writes use a tempfile-then-rename pattern (RenderInventory.atomic_write) so a
# parse during another generation of the SAME profile can't yield a truncated
# file.
#
# Subdirectory layout (rather than profile-suffixed filenames) preserves
# ansible's auto-discovery of `<inventory_dir>/group_vars/all.yml` — each
# profile's `all.yml` lives adjacent to its own inventory, so standalone
# `ansible-playbook -i .../static.ini` invocations pick up the right vars
# without needing -e overrides. Pre-existing `inventory/static.ini` and
# `inventory/pqc.ini` from before this change are left in place (no
# destructive cleanup) but no longer read by the orchestration.
#===============================================================================
DOTFILE_DIR    = PROFILE[:dotfile_dir]
PROFILE_INV_DIR = File.join(ANSIBLE_DIR, "inventory", PROFILE[:name])
INVENTORY_PATH = File.join(PROFILE_INV_DIR, "static.ini")

# INVENTORY_HOSTS derived from topology.yml: os==windows -> winrm, else ssh.
# Filtered to the active profile below.
# Defined unconditionally (cheap, side-effect-free) because RenderInventory.run
# needs it and the generation guard below may skip the run entirely.
INVENTORY_HOSTS = Topology.names.each_with_object({}) do |name, h|
  h[name] = { ip: Topology.ip(name),
              type: Topology.os(name) == 'windows' ? :winrm : :ssh }
end
INVENTORY_HOSTS = INVENTORY_HOSTS.select { |name, _| COMPONENTS.include?(name) }

#===============================================================================
# Inventory generation is an EXPLICIT step.
#===============================================================================
# Previously the static.ini / pqc.ini / group_vars/all.yml generation ran as a
# parse-time SIDE EFFECT — so every `vagrant status`, ssh-config, or
# tab-completion parse rewrote those shared files. The generation logic now
# lives in lib/render_inventory.rb and runs ONLY when explicitly requested
# (up.sh / render-inventory.sh set LAB_RENDER_INVENTORY=1) or when the inventory
# doesn't exist yet (first-run correctness). A bare `vagrant status` no longer
# mutates shared files. Generated CONTENTS are byte-identical to before.
require_relative 'lib/render_inventory'
if ENV['LAB_RENDER_INVENTORY'] == '1' || !File.exist?(INVENTORY_PATH)
  RenderInventory.run(
    profile_name: PROFILE[:name], components: COMPONENTS,
    inventory_hosts: INVENTORY_HOSTS, dotfile_dir: DOTFILE_DIR,
    profile_inv_dir: PROFILE_INV_DIR,
    winrm_vars_base: WINRM_VARS_BASE, ssh_vars_base: SSH_VARS_BASE,
    common_vars: COMMON_VARS, ejbca_vars: EJBCA_VARS,
    stepca_vars: STEPCA_VARS, hydra_vars: HYDRA_VARS,
    vagrant_root: File.dirname(__FILE__))
end

Vagrant.configure("2") do |config|

  # Global settings
  config.vm.communicator = "winrm"
  config.winrm.username = "vagrant"
  config.winrm.password = "vagrant"
  config.winrm.transport = :plaintext    # Basic auth — survives DC promo
  config.winrm.timeout = 1800
  config.winrm.retry_limit = 30
  config.vm.boot_timeout = 1800
  config.vm.graceful_halt_timeout = 600

  # Auto-corrected forwarded ports (the box-defined WinRM/RDP/SSH maps) land in
  # this range on collision. Vagrant's default 2200..2250 is 51 ports — at 4
  # forwards per Windows VM that is a hard host-wide ceiling of ~12 concurrent
  # VMs, hit 2026-07-01 launching `full` alongside three running labs ("the
  # ports in the auto-correction range are all also used"). Give each lab its
  # own disjoint 800-port window keyed off the lab subnet (same idea as
  # PORT_OFFSET): .56 → 2200..2999, .57 → 3200..3999, … — 800 ports ≈ 200 VMs
  # per lab, and simultaneously-launching labs can't race each other for the
  # same host ports. Windows never overlap the static 2xxxx+PORT_OFFSET maps.
  config.vm.usable_port_range = (2200 + PORT_OFFSET)..(2999 + PORT_OFFSET)

  # The base box ships its own Guest Additions. When the host VirtualBox version
  # differs from the box GA, the vagrant-vbguest plugin tries to auto-update the
  # guest Additions on boot — which crashes on Ruby 3.3 (File.exists? was removed)
  # in vbguest 0.32.0 and aborts `vagrant up`. Host 7.2.x and box GA 7.2.x are
  # compatible, so disable the auto-update entirely (guarded for hosts without
  # the plugin installed).
  if Vagrant.has_plugin?("vagrant-vbguest")
    config.vbguest.auto_update = false
  end

  # Disable default synced folder (causes issues on Windows guests)
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # Mount local caches on Windows VMs (PSFramework module + staged software)
  mount_shares = ->(vm) {
    vm.vm.synced_folder PSF_PATH, "C:/PSModules", type: "virtualbox" if PSF_AVAILABLE
    vm.vm.synced_folder SOFTWARE_PATH, "C:/Software", type: "virtualbox" if SOFTWARE_AVAILABLE
  }

  #=============================================================================
  # DC1 - Primary Domain Controller
  #=============================================================================
  if COMPONENTS.include?("dc1")
  config.vm.define "dc1", primary: true do |dc|
    set_box(dc, BOX_WIN_SERVER_CORE)
    dc.vm.hostname = "DC1"
    dc.vm.network "private_network", ip: IP_ADDRESSES[:dc1]
    mount_shares.call(dc)

    dc.vm.provider "virtualbox" do |vb|
      vb.name = "#{VB_PREFIX}-dc1"
      vb.memory = vm_memory("dc1", VM_DEFAULTS[:dc][:memory])
      vb.cpus = vm_cpus("dc1", VM_DEFAULTS[:dc][:cpus])
      vb.gui = false
    end

    dc.vm.provision "ansible" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/dc1.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge({ ip_address: IP_ADDRESSES[:dc1] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end

    # Publish EJBCA Root CA cert to AD (run manually after EJBCA1 is provisioned)
    dc.vm.provision "ejbca-trust", type: "ansible", run: "never" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/ejbca-trust.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge(EJBCA_VARS).merge({ ip_address: IP_ADDRESSES[:dc1] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end

    # Publish step-ca Root CA cert to AD (run manually after STEPCA1 is provisioned)
    dc.vm.provision "stepca-trust", type: "ansible", run: "never" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/stepca-trust.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge(STEPCA_VARS).merge({ ip_address: IP_ADDRESSES[:dc1] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end
  end
  end  # COMPONENTS.include?("dc1")

  #=============================================================================
  # DC2 - Secondary Domain Controller (Optional)
  #=============================================================================
  if COMPONENTS.include?("dc2")
  config.vm.define "dc2", autostart: false do |dc|
    set_box(dc, BOX_WIN_SERVER_CORE)
    dc.vm.hostname = "DC2"
    dc.vm.network "private_network", ip: IP_ADDRESSES[:dc2]
    mount_shares.call(dc)

    dc.vm.provider "virtualbox" do |vb|
      vb.name = "#{VB_PREFIX}-dc2"
      vb.memory = vm_memory("dc2", VM_DEFAULTS[:dc][:memory])
      vb.cpus = vm_cpus("dc2", VM_DEFAULTS[:dc][:cpus])
      vb.gui = false
    end

    dc.vm.provision "ansible" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/dc2.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge({ ip_address: IP_ADDRESSES[:dc2] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end
  end
  end  # COMPONENTS.include?("dc2")

  #=============================================================================
  # CA VMs — topology-dependent
  #=============================================================================
  # CA1 - Combined Root/Issuing CA (one-tier)
  if COMPONENTS.include?("ca1")
  config.vm.define "ca1" do |ca|
    set_box(ca, BOX_WIN_SERVER_CORE)
    ca.vm.hostname = "CA1"
    ca.vm.network "private_network", ip: IP_ADDRESSES[:ca1]
    mount_shares.call(ca)

    ca.vm.provider "virtualbox" do |vb|
      vb.name = "#{VB_PREFIX}-ca1"
      vb.memory = vm_memory("ca1", VM_DEFAULTS[:ca][:memory])
      vb.cpus = vm_cpus("ca1", VM_DEFAULTS[:ca][:cpus])
      vb.gui = false
    end

    ca.vm.provision "ansible" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/ca.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge(PKI_VARS).merge({ ip_address: IP_ADDRESSES[:ca1] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end
  end
  end  # COMPONENTS.include?("ca1")

  # ROOTCA - Offline Standalone Root CA (NOT domain-joined, two-tier)
  if COMPONENTS.include?("rootca")
  config.vm.define "rootca" do |ca|
    set_box(ca, BOX_WIN_SERVER_CORE)
    ca.vm.hostname = "ROOTCA"
    ca.vm.network "private_network", ip: IP_ADDRESSES[:rootca]
    mount_shares.call(ca)

    ca.vm.provider "virtualbox" do |vb|
      vb.name = "#{VB_PREFIX}-rootca"
      vb.memory = vm_memory("rootca", VM_DEFAULTS[:ca][:memory])
      vb.cpus = vm_cpus("rootca", VM_DEFAULTS[:ca][:cpus])
      vb.gui = false
    end

    ca.vm.provision "ansible" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/ca.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge(ROOT_CA_VARS).merge({ ip_address: IP_ADDRESSES[:rootca] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end
  end
  end  # COMPONENTS.include?("rootca")

  # ISSUECA - Online Enterprise Issuing CA (Subordinate, two-tier)
  if COMPONENTS.include?("issueca")
  config.vm.define "issueca" do |ca|
    set_box(ca, BOX_WIN_SERVER_CORE)
    ca.vm.hostname = "ISSUECA"
    ca.vm.network "private_network", ip: IP_ADDRESSES[:issueca]
    mount_shares.call(ca)

    ca.vm.provider "virtualbox" do |vb|
      vb.name = "#{VB_PREFIX}-issueca"
      vb.memory = vm_memory("issueca", VM_DEFAULTS[:ca][:memory])
      vb.cpus = vm_cpus("issueca", VM_DEFAULTS[:ca][:cpus])
      vb.gui = false
    end

    ca.vm.provision "ansible" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/ca.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"

  #=============================================================================
  # TOMCAT1 - Apache Tomcat + OpenJDK 17 (Optional)
  #=============================================================================
  if COMPONENTS.include?("tomcat1")
  config.vm.define "tomcat1", autostart: false do |tc|
    set_box(tc, BOX_WIN_SERVER)
    tc.vm.hostname = "TOMCAT1"
    tc.vm.network "private_network", ip: IP_ADDRESSES[:tomcat1]
    mount_shares.call(tc)

    # Static port forwards — avoids TOCTOU race with concurrent vagrant up
    # PORT_OFFSET shifts ports when running on a non-default subnet (e.g. 192.168.57)
    tc.vm.network "forwarded_port", guest: 3389, host: 23389 + PORT_OFFSET, auto_correct: false
    tc.vm.network "forwarded_port", guest: 5985, host: 25985 + PORT_OFFSET, auto_correct: false
    tc.vm.network "forwarded_port", guest: 5986, host: 25986 + PORT_OFFSET, auto_correct: false
    tc.vm.network "forwarded_port", guest: 22,   host: 22060 + PORT_OFFSET, auto_correct: false

    tc.vm.provider "virtualbox" do |vb|
      vb.name = "#{VB_PREFIX}-tomcat1"
      vb.memory = vm_memory("tomcat1", VM_DEFAULTS[:tomcat][:memory])
      vb.cpus = vm_cpus("tomcat1", VM_DEFAULTS[:tomcat][:cpus])
      vb.gui = false
      vb.customize ["modifyvm", :id, "--clipboard-mode", "bidirectional"]
      vb.customize ["modifyvm", :id, "--draganddrop", "bidirectional"]
      vb.customize ["modifyvm", :id, "--vram", "128"]
    end

    # Phase 1: domain join (reboots VM, breaks VBoxSF on Desktop Experience boxes)
    tc.vm.provision "ansible" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/tomcat1-phase1.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge({ ip_address: IP_ADDRESSES[:tomcat1] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end

    # Reload restores VBoxSF shared folders after domain join reboot
    tc.vm.provision :reload

    # Phase 2: application roles (tomcat, certs, winlogbeat — need C:\Software)
    tc.vm.provision "phase2", type: "ansible" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/tomcat1-phase2.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge({ ip_address: IP_ADDRESSES[:tomcat1] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end
  end
  end  # COMPONENTS.include?("tomcat1")

  #=============================================================================
  # WSUS1 - Windows Server Update Services (Optional)
  #=============================================================================
  if COMPONENTS.include?("wsus1")
  config.vm.define "wsus1", autostart: false do |wsus|
    set_box(wsus, BOX_WIN_SERVER_CORE)
    wsus.vm.hostname = "WSUS1"
    wsus.vm.network "private_network", ip: IP_ADDRESSES[:wsus1]
    mount_shares.call(wsus)

    wsus.vm.provider "virtualbox" do |vb|
      vb.name = "#{VB_PREFIX}-wsus1"
      vb.memory = vm_memory("wsus1", VM_DEFAULTS[:wsus][:memory])
      vb.cpus = vm_cpus("wsus1", VM_DEFAULTS[:wsus][:cpus])
      vb.gui = false

      # Dedicated WSUS content disk (D:\WSUS instead of C:\WSUS)
      if WSUS_CONTENT_DISK_GB > 0
        wsus_disk = File.join(Dir.home, "VirtualBox VMs", vb.name, "wsus-data.vdi")
        unless File.exist?(wsus_disk)
          vb.customize ["createmedium", "disk",
                         "--filename", wsus_disk,
                         "--size", WSUS_CONTENT_DISK_GB * 1024,
                         "--format", "VDI"]
        end
        vb.customize ["storageattach", :id,
                       "--storagectl", "SATA Controller",
                       "--port", 1, "--device", 0,
                       "--type", "hdd",
                       "--medium", wsus_disk]
      end
    end

    wsus.vm.provision "ansible" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/wsus1.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge(WSUS_VARS).merge({ ip_address: IP_ADDRESSES[:wsus1] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end

    # Explicit WsusContent capture (run after content download completes):
    #   scripts/cache-wsus.sh  →  vagrant provision wsus1 --provision-with wsus-capture
    wsus.vm.provision "wsus-capture", type: "ansible", run: "never" do |ansible|
      ansible.playbook = "#{ANSIBLE_DIR}/playbooks/wsus-capture.yml"
      ansible.config_file = "#{ANSIBLE_DIR}/ansible.cfg"
      ansible.extra_vars = COMMON_VARS.merge(WSUS_VARS).merge({ ip_address: IP_ADDRESSES[:wsus1] })
      ansible.inventory_path = INVENTORY_PATH
      ansible.compatibility_mode = "2.0"
    end
  end
  end  # COMPONENTS.include?("wsus1")


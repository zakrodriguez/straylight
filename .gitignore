.vagrant/
.vagrant-*/
vagrant/resources/psframework/
vagrant/logs/
vagrant/ansible/inventory/static.ini
vagrant/ansible/inventory/pqc.ini
vagrant/ansible/inventory/group_vars/
# Per-profile inventory directories rendered by the Vagrantfile at parse time.
# Layout: vagrant/ansible/inventory/<profile-name>/{static.ini,pqc.ini,group_vars/all.yml}
# Each profile has its own dir so concurrent `LAB_PROFILE=... vagrant ...`
# invocations don't clobber each other's inventory. The three legacy entries
# above are kept so any pre-migration files left in working trees remain
# ignored — no destructive cleanup of those.
vagrant/ansible/inventory/*/
vagrant/cbom-export/
vagrant/cbom-*.json
docs/v1.0-baselines-logs/
vagrant/.verify-logs/
# Python bytecode caches (e.g. from vagrant/scripts and cbom-toolkit tooling)
__pycache__/
*.pyc
# Recall plugin local session memory (per-machine; may capture conversation content)
.recall/
# Understand-Anything generated knowledge graph + analysis cache (regenerable via /understand)
.understand-anything/
# GSD session-continuity checkpoints (per-machine; auto-generated by the auto-postool hook)
.planning/
# Recall plugin local config (per-machine maintainer tooling)
recall.config.json
# Editor-local settings / authoring instructions (maintainer tooling)
.vscode/
# Internal planning/design history — excluded from the public tree (retained in git history)
archive/
docs/superpowers/

# graphify knowledge-graph build artifacts
graphify-out/

# Maintainer-local scratch notes (not part of the published tree)
buildmon-test-instructions.txt
